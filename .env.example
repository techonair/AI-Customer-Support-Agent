# .env.example - template for local development
# Copy this file to .env and fill in secret values. Do NOT commit your .env to source control.

# Default model to use for OpenAI-compatible requests
OPENAI_DEFAULT_MODEL=llama-3.3-70b-versatile

# Groq (LLama-compatible) API base URL
LLAMA_API_BASE_URL=https://api.groq.com/openai/v1

# Your Groq API key - replace with your secret in your local .env
LLAMA_API_KEY=REPLACE_WITH_YOUR_LLAMA_API_KEY

# Notes:
# - Add ".env" to your .gitignore if it's not already ignored.
# - On Windows PowerShell, load env for the current session: $env:LLAMA_API_KEY="<your_key>"
# - To persist across sessions: setx LLAMA_API_KEY "<your_key>"
